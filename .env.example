# HuggingFace API token for LLM-in-the-loop autonomous experiment design
HF_TOKEN=your_huggingface_token_here

# Optional: override model (default: mistralai/Mistral-7B-Instruct-v0.3)
BIOML_LLM_MODEL=Qwen/Qwen3.5-397B-A17B

# Optional: max experiments per autonomous run
BIOML_MAX_EXPERIMENTS=20

# Optional: time budget per experiment in seconds (default: 300)
BIOML_TIME_BUDGET=300
